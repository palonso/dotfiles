# Other theme options, don't look as good for me
# theme = TokyoNight Moon

theme = Catppuccin Macchiato

# Background transparency (0.0 = fully transparent, 1.0 = opaque)
# background-opacity = 0.80

# Optional: nicer spacing
window-padding-x = 12
window-padding-y = 10

# Optional: cursor & font tweaks
cursor-style = block
font-size = 13

# Do not ask for permissions to read from the clipboard
clipboard-read = allow

# Do not show the title bar, since it looks bad with the theme and I don't need it
window-decoration = false
